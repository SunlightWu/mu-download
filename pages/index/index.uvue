						<text class="tool-icon">提取</text>
					</view>
					<text class="tool-name">音频提取</text>
				</view>
			</view>
		</view>
		
		<!-- 更多工具（预留） -->
		<view class="section">
			<text class="section-title">更多工具</text>
			<view class="tool-grid">
				<view class="tool-item tool-disabled">
					<view class="tool-icon-wrapper tool-icon-gray">
						<text class="tool-icon">二维码</text>
					</view>
					<text class="tool-name">扫码/生成</text>
				</view>
				
				<view class="tool-item tool-disabled">
					<view class="tool-icon-wrapper tool-icon-gray">
						<text class="tool-icon">JSON</text>
					</view>
					<text class="tool-name">JSON格式化</text>
				</view>
				
				<view class="tool-item tool-disabled">
					<view class="tool-icon-wrapper tool-icon-gray">
						<text class="tool-icon">Base64</text>
					</view>
					<text class="tool-name">编解码</text>
				</view>
				
				<view class="tool-item tool-disabled">
					<view class="tool-icon-wrapper tool-icon-gray">
						<text class="tool-icon">...</text>
					</view>
					<text class="tool-name">敬请期待</text>
				</view>
			</view>
		</view>
		
		<!-- 下载记录入口 -->
		<view class="section" v-if="recentTasks.length > 0">
			<view class="section-header">
				<text class="section-title">下载记录</text>
				<text class="section-more" @click="goToHistory">查看全部 ›</text>
			</view>
			<view class="recent-list">
				<view 
					v-for="task in recentTasks" 
					:key="task.id" 
					class="recent-item"
					@click="goToDetail(task.id)"
				>
					<text class="recent-name">{{ task.fileName }}</text>
					<text class="recent-status" :class="'status-' + task.status">
						{{ getStatusText(task.status) }}
					</text>
				</view>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	type TaskStatus = 'pending' | 'downloading' | 'paused' | 'completed' | 'failed' | 'merging'
	
	type RecentTask = {
		id : string
		fileName : string
		status : TaskStatus
	}
	
	const recentTasks = ref<RecentTask[]>([])
	
	const getStatusText = (status : TaskStatus) : string => {
		switch (status) {
			case 'pending': return '等待中'
			case 'downloading': return '下载中'
			case 'paused': return '已暂停'
			case 'completed': return '已完成'
			case 'failed': return '失败'
			case 'merging': return '合并中'
			default: return '未知'
		}
	}
	
	const loadRecentTasks = () : void => {
		try {
			const data = uni.getStorageSync('download_tasks') as string
			if (data.length > 0) {
				const parsed = JSON.parseArray(data)
				if (parsed != null) {
					const list : RecentTask[] = []
					const count = Math.min(parsed.length, 3)
					for (let i = 0; i < count; i++) {
						const t = parsed[i] as UTSJSONObject
						const config = t.getJSON('config')
						if (config != null) {
							const statusStr = t.getString('status') ?? 'pending'
							let status : TaskStatus = 'pending'
							if (statusStr.indexOf('下载中') != -1) {
								status = 'downloading'
							} else if (statusStr.indexOf('完成') != -1) {
								status = 'completed'
							} else if (statusStr.indexOf('失败') != -1) {
								status = 'failed'
							} else if (statusStr.indexOf('暂停') != -1) {
								status = 'paused'
							} else if (statusStr.indexOf('合并') != -1) {
								status = 'merging'
							}
							list.push({
								id: config.getString('id') ?? '',
								fileName: config.getString('fileName') ?? '',
								status: status
							})
						}
					}
					recentTasks.value = list
				}
			}
		} catch (e) {
			console.error('加载记录失败', e)
		}
	}
	
	const goToM3u8 = () : void => {
		uni.navigateTo({
			url: '/pages/m3u8/input'
		})
	}
	
	const goToHistory = () : void => {
		uni.navigateTo({
			url: '/pages/history/index'
		})
	}
	
	const goToDetail = (taskId : string) : void => {
		uni.navigateTo({
			url: `/pages/m3u8/detail?taskId=${taskId}`
		})
	}
	
	onShow(() => {
		loadRecentTasks()
	})
</script>

