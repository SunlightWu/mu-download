<template>
	<view class="container">
		<view class="header">
			<text class="app-title">工具箱</text>
			<text class="app-desc">实用工具集合</text>
		</view>
		
		<!-- 工具分类 -->
		<view class="section">
			<text class="section-title">视频工具</text>
			<view class="tool-grid">
				<view class="tool-item" @click="goToM3u8">
					<view class="tool-icon-wrapper tool-icon-blue">
						<text class="tool-icon">M3U8</text>
					</view>
					<text class="tool-name">M3U8下载</text>
				</view>
				
				<view class="tool-item tool-disabled">
					<view class="tool-icon-wrapper tool-icon-gray">
