		border-radius: 8rpx;
	}
	
	.control-input {
		width: 100rpx;
		height: 60rpx;
		font-size: 32rpx;
		font-weight: bold;
		color: #333333;
		text-align: center;
		background-color: #f5f5f5;
		border-radius: 8rpx;
		margin: 0 10rpx;
	}
	
	.filename-section {
		background-color: #ffffff;
		border-radius: 16rpx;
		padding: 24rpx;
		margin-bottom: 20rpx;
	}
	
	.filename-label {
		font-size: 28rpx;
		color: #333333;
		margin-bottom: 16rpx;
	}
	
	.filename-input-wrapper {
		flex-direction: row;
		align-items: center;
		background-color: #f5f5f5;
