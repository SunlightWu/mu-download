	}
	
	.settings-section {
		background-color: #ffffff;
		border-radius: 16rpx;
		padding: 24rpx;
		margin-bottom: 20rpx;
	}
	
	.setting-row {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
	}
	
	.setting-label {
		font-size: 28rpx;
